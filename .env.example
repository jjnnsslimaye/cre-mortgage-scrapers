# AWS S3 Configuration
# Copy this file to .env and fill in your values
#
# For local development:
#   cp .env.example .env
#
# For Railway deployment:
#   Set these as environment variables in Railway dashboard

# Required for S3 uploads (--upload-to-s3 flag)
S3_BUCKET=your-bucket-name
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key

# Optional - AWS region (defaults to us-east-1)
AWS_REGION=us-east-1

# ============================================================================
# NOTIFICATIONS & ALERTING (Optional)
# ============================================================================

# Slack Webhook (get from: https://api.slack.com/messaging/webhooks)
SLACK_WEBHOOK_URL=

# Discord Webhook (get from: Server Settings > Integrations > Webhooks)
DISCORD_WEBHOOK_URL=

# Generic Webhook (receives JSON payload with metrics)
WEBHOOK_URL=

# Email Notifications
EMAIL_NOTIFICATIONS=true
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=joshua.nishad.limaye@gmail.com
SMTP_PASSWORD=
EMAIL_FROM=joshua.nishad.limaye@gmail.com
EMAIL_TO=joshua.nishad.limaye@gmail.com
